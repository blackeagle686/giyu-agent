          "language": "json",
          "code": "[\n  {\n    \"name\": \"Primary Database\",\n    \"host\": \"db.internal.company.local\",\n    \"port\": 5432,\n    \"protocol\": \"tcp\",\n    \"type\": \"internal\"\n  },\n  {\n    \"name\": \"Application Server\",\n    \"host\": \"app-server-01.internal.company.local\",\n    \"port\": 8080,\n    \"protocol\": \"tcp\",\n    \"type\": \"internal\"\n  },\n  {\n    \"name\": \"API Gateway\",\n    \"host\": \"api-gateway.external.com\",\n    \"port\": 443,\n    \"protocol\": \"https\",\n    \"type\": \"external\"\n  },\n  {\n    \"name\": \"DNS Resolver\",\n    \"host\": \"8.8.8.8\",\n    \"port\": 53,\n    \"protocol\": \"udp\",\n    \"type\": \"external\"\n  }\n]",
          "edits": []
        },
        {
          "type": "terminal",
          "path": "./validate_endpoints.sh",
          "language": "bash",
          "code": "#!/bin/bash\n# Validate connectivity to critical endpoints defined in critical_endpoints.json\necho \"Validating critical endpoint connectivity...\"\ndeclare -a endpoints\nendpoints=(\n  \"db.internal.company.local:5432\"\n  \"app-server-01.internal.company.local:8080\"\n  \"api-gateway.external.com:443\"\n  \"8.8.8.8:53\"\n)\nfor endpoint in \"${endpoints[@]}\"; do\n  host=$(echo $endpoint | cut -d':' -f1)\n  port=$(echo $endpoint | cut -d':' -f2)\n  echo \"Testing $endpoint...\"\n  timeout 5 bash -c \"</dev/tcp/$host/$port\" >/dev/null 2>&1 && echo \"  ✅ Connected\" || echo \"  ❌ Failed\"\ndone",
          "edits": []
        }
      ],
