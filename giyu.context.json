  "plans": [
    {
      "plan_step_id": 1,
      "task_id": 1,
      "step_index": 1,
      "type": "analysis",
      "solution": {
        "approach": "Identify the target external endpoint to test connectivity. Select a reliable, publicly accessible service such as Google's public DNS (8.8.8.8) or an HTTP-based probe like http://www.google.com. Determine whether to use ICMP (ping), DNS resolution, or HTTP request methods based on system permissions and desired verbosity. Ensure no configuration changes are made to network settings during testing.",
        "algorithm": "Choose probe type: DNS or HTTP. Set timeout and retry parameters. Record baseline network state if possible.",
        "complexity": "O(1)"
      },
      "dependencies": [],
      "status": "done"
    },
    {
      "plan_step_id": 2,
      "task_id": 1,
      "step_index": 2,
      "type": "design",
      "solution": {
        "approach": "Design a non-intrusive connectivity test using standard tools available in most environments. For DNS: execute 'dig @8.8.8.8 example.com' or 'nslookup example.com 8.8.8.8'. For HTTP: use curl or wget with --connect-timeout and --max-time flags to avoid hanging. Log output without altering firewall rules, routing tables, or proxy configurations.",
        "algorithm": "If DNS method preferred → resolve known domain via public resolver. Else → send HEAD/GET request to HTTPS endpoint with short timeout.",
        "complexity": "O(1)"
      },
      "dependencies": [
        1
      ],
      "status": "pending"
    },
    {
      "plan_step_id": 3,
      "task_id": 1,
      "step_index": 3,
      "type": "implementation",
      "solution": {
        "approach": "Execute the designed test command(s) in a controlled manner. Run either a DNS query or an HTTP request to a trusted external host (e.g., 8.8.8.8 for DNS or https://www.google.com for HTTP). Capture exit code and response time. Do not modify any local network policies or state—only observe and report.",
        "algorithm": "Run: nslookup -timeout=5 www.google.com 8.8.8.8 || curl -m 5 -s --head https://www.google.com; echo $?",
        "complexity": "O(1)"
      },
      "dependencies": [
        2
      ],
      "status": "pending"
    },
    {
      "plan_step_id": 4,
      "task_id": 1,
      "step_index": 4,
      "type": "validation",
      "solution": {
        "approach": "Evaluate the outcome of the connectivity attempt. A successful test is indicated by a zero exit code from the command, received response data, or resolved IP address. If both DNS and HTTP methods are used, validate consistency between results. Log the result and conclude whether outbound internet access is functional.",
        "algorithm": "Check exit status: if [ $? -eq 0 ]; then echo 'Connectivity OK'; else echo 'Failure'; fi",
        "complexity": "O(1)"
      },
