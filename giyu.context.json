    {
      "generate_block_id": 1,
      "plan_step_id": 4,
      "artifacts": [
        {
          "type": "terminal",
          "path": ".",
          "language": "bash",
          "code": "nvidia-smi --query-gpu=index,name,temperature.gpu,utilization.gpu,memory.total,memory.used,memory.free,power.draw --format=csv,noheader,nounits"
        },
        {
          "type": "file_write",
          "path": "./gpu_monitor.py",
          "language": "python",
          "code": "import subprocess\nimport sys\n\ndef parse_nvidia_smi():\n    try:\n        result = subprocess.run(\n            ['nvidia-smi', '--query-gpu=index,name,temperature.gpu,utilization.gpu,memory.total,memory.used,memory.free,power.draw', '--format=csv,noheader,nounits'],\n            stdout=subprocess.PIPE,\n            stderr=subprocess.PIPE,\n            text=True,\n            check=True\n        )\n        lines = [line.strip().split(', ') for line in result.stdout.strip().split('\\n') if line.strip()]\n        return lines\n    except Exception as e:\n        print(f\"Error running nvidia-smi: {e}\", file=sys.stderr)\n        return []\n\ndef validate_gpu_metrics(gpu_data):\n    anomalies = []\n    for i, gpu in enumerate(gpu_data):\n        index = gpu[0]\n        temp = int(gpu[2])\n        util_gpu = int(gpu[3])\n        mem_total = int(gpu[4])\n        mem_used = int(gpu[5])\n        mem_free = int(gpu[6])\n        power_draw = float(gpu[7])\n        \n        if temp >= 85:\n            anomalies.append(f\"GPU {index}: Temperature too high ({temp}°C)\")\n        \n        if mem_used >= mem_total:\n            anomalies.append(f\"GPU {index}: Memory usage at or above 100% ({mem_used}/{mem_total})\")\n        \n        if util_gpu >= 95:\n            anomalies.append(f\"GPU {index}: High GPU utilization ({util_gpu}%)\")\n        \n        if power_draw > 300:\n            anomalies.append(f\"GPU {index}: High power draw ({power_draw}W)\")\n    \n    return anomalies\n\ndef main():\n    gpu_data = parse_nvidia_smi()\n    if not gpu_data:\n        print(\"No GPU data retrieved.\")\n        return\n    \n    anomalies = validate_gpu_metrics(gpu_data)\n    if anomalies:\n        for anomaly in anomalies:\n            print(f\"WARNING: {anomaly}\")\n    else:\n        print(\"All GPU metrics within acceptable thresholds.\")\n\nif __name__ == \"__main__\":\n    main()"
        }
      ],
      "status": "success",
