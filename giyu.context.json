      "artifacts": [
        {
          "type": "terminal",
          "path": ".",
          "language": "bash",
          "code": "last -F | grep -E 'failed|unauthorized|denied' || echo 'No failed login attempts found in lastlog.'",
          "edits": []
        },
        {
          "type": "terminal",
          "path": ".",
          "language": "bash",
          "code": "who --ips | awk '{print $1, $3}' | sort | uniq -c | sort -nr",
          "edits": []
        },
        {
          "type": "terminal",
          "path": ".",
          "language": "bash",
          "code": "journalctl --since '1 hour ago' --grep='failed\\|unauthorized\\|denied\\|error' -i",
          "edits": []
        }
      ],
      "status": "success",
