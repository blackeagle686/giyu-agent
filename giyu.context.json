        {
          "type": "file_write",
          "path": "probe_network.py",
          "language": "python",
          "code": "#!/usr/bin/env python3\n\"\"\"\nNetwork Connectivity Probe Tool\nTests connectivity to external endpoints using DNS or HTTP methods.\nSupports configurable timeout and retry parameters.\n\"\"\"\n\nimport socket\nimport requests\nimport time\nimport sys\nfrom typing import Optional, Dict, Any\n\nclass NetworkProbe:\n    def __init__(self, method: str = \"dns\", host: str = \"8.8.8.8\", port: int = 53,\n                 timeout: float = 5.0, retries: int = 3):\n        self.method = method.lower()\n        self.host = host\n        self.port = port\n        self.timeout = timeout\n        self.retries = retries\n        \n        if self.method not in [\"dns\", \"http\"]:\n            raise ValueError(\"Method must be 'dns' or 'http'\")\n    \n    def probe_dns(self) -> Dict[str, Any]:\n        \"\"\"Perform DNS resolution probe.\"\"\"\n        result = {\"success\": False, \"duration\": None, \"error\": None}\n        start_time = time.time()\n        \n        for attempt in range(self.retries):\n            try:\n                socket.setdefaulttimeout(self.timeout)\n                resolved = socket.gethostbyname(self.host)\n                duration = time.time() - start_time\n                result.update({\n                    \"success\": True,\n                    \"duration\": round(duration, 3),\n                    \"resolved_ip\": resolved,\n                    \"attempts\": attempt + 1\n                })\n                break\n            except socket.gaierror as e:\n                result[\"error\"] = f\"DNS resolution failed: {e}\"\n                if attempt == self.retries - 1:\n                    duration = time.time() - start_time\n                    result[\"duration\"] = round(duration, 3)\n            except Exception as e:\n                result[\"error\"] = f\"Unexpected error: {e}\"\n                break\n        \n        return result\n    \n    def probe_http(self) -> Dict[str, Any]:\n        \"\"\"Perform HTTP request probe.\"\"\"\n        result = {\"success\": False, \"duration\": None, \"status_code\": None, \"error\": None}\n        url = f\"http://{self.host}\" if self.port == 80 else f\"http://{self.host}:{self.port}\"\n        \n        for attempt in range(self.retries):\n            try:\n                start_time = time.time()\n                response = requests.get(url, timeout=self.timeout)\n                duration = time.time() - start_time\n                \n                result.update({\n                    \"success\": True,\n                    \"duration\": round(duration, 3),\n                    \"status_code\": response.status_code,\n                    \"attempts\": attempt + 1\n                })\n                break\n            except requests.exceptions.RequestException as e:\n                result[\"error\"] = f\"HTTP request failed: {e}\"\n                if attempt == self.retries - 1:\n                    duration = time.time() - start_time\n                    result[\"duration\"] = round(duration, 3)\n            except Exception as e:\n                result[\"error\"] = f\"Unexpected error: {e}\"\n                break\n        \n        return result\n    \n    def run(self) -> Dict[str, Any]:\n        \"\"\"Execute the network probe based on configured method.\"\"\"\n        print(f\"Probing {self.host} using {self.method.upper()}...\")\n        print(f\"Timeout: {self.timeout}s, Retries: {self.retries}\")\n        \n        if self.method == \"dns\":\n            return self.probe_dns()\n        elif self.method == \"http\":\n            return self.probe_http()\n        else:\n            return {\"success\": False, \"error\": \"Invalid method\"}\n\ndef main():\n    # Default configuration for Google's public DNS\n    probe = NetworkProbe(\n        method=\"dns\",\n        host=\"8.8.8.8\",\n        timeout=5.0,\n        retries=3\n    )\n    \n    result = probe.run()\n    \n    print(\"\\nResults:\")\n    print(f\"Success: {result['success']}\")\n    if result.get('duration'):\n        print(f\"Duration: {result['duration']}s\")\n    if result.get('resolved_ip'):\n        print(f\"Resolved IP: {result['resolved_ip']}\")\n    if result.get('status_code'):\n        print(f\"Status Code: {result['status_code']}\")\n    if result.get('error'):\n        print(f\"Error: {result['error']}\")\n    \n    sys.exit(0 if result['success'] else 1)\n\nif __name__ == \"__main__\":\n    main()\n",
          "edits": []
        },
