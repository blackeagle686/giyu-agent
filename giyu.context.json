      "artifacts": [
        {
          "type": "terminal",
          "path": ".",
          "language": "bash",
          "code": "grep -i 'failed password\\|invalid user\\|unauthorized access' /var/log/auth.log | tail -20"
        },
        {
          "type": "terminal",
          "path": ".",
          "language": "bash",
          "code": "journalctl --since '1 hour ago' | grep -i 'authentication failure\\|login failed'"
        },
        {
          "type": "terminal",
          "path": ".",
          "language": "bash",
          "code": "ss -tulnp | grep -v 'ESTABLISHED' && ss -tnp state established | awk '{print $5, $6}' | sort | uniq -c | sort -nr | head -10"
        },
        {
          "type": "terminal",
          "path": ".",
          "language": "bash",
          "code": "lastb | head -10"
        }
      ],
