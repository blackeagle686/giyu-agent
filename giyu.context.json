      "type": "design",
      "solution": {
        "approach": "Design a monitoring strategy using nvidia-smi to extract key metrics: GPU utilization percentage, current temperature (in °C), and used/free memory. Parse the output of 'nvidia-smi --query-gpu=utilization.gpu,temperature.gpu,memory.used,memory.total --format=csv,noheader,nounits' to capture these values in a structured format.",
        "algorithm": "Execute CLI command to query specific GPU attributes and format output as CSV for easy parsing.",
        "complexity": "O(n) where n is number of GPUs"
      },
      "dependencies": [
        "1"
      ],
      "status": "done"
    },
