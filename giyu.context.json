      "artifacts": [
        {
          "type": "file_write",
          "path": "./tail_logs.sh",
          "language": "bash",
          "code": "#!/bin/bash\n# Tail the last 100 lines of a specified log file or systemd journal\n\nLOG_FILE=\"\"\nOUTPUT_FORMAT=\"text\"  # Options: text, json\nLINE_COUNT=100\n\nwhile [[ $# -gt 0 ]]; do\n  case $1 in\n    -f|--file)\n      LOG_FILE=\"$2\"\n      shift 2\n      ;;\n    -l|--lines)\n      LINE_COUNT=\"$2\"\n      shift 2\n      ;;\n    -j|--json)\n      OUTPUT_FORMAT=\"json\"\n      shift\n      ;;\n    --help)\n      echo \"Usage: $0 [OPTIONS]\"\n      echo \"Options:\"\n      echo \"  -f, --file FILE     Path to log file (default: journalctl)\"\n      echo \"  -l, --lines N     Number of lines to display (default: 100)\"\n      echo \"  -j, --json        Output in JSON format if supported\"\n      echo \"  --help            Show this help message\"\n      exit 0\n      ;;\n    *)\n      echo \"Unknown option: $1\" >&2\n      exit 1\n      ;;\n  esac\ndone\n\nif [[ -z \"$LOG_FILE\" ]]; then\n  if command -v journalctl > /dev/null; then\n    journalctl -n \"$LINE_COUNT\"\n  else\n    echo \"Error: No log file provided and journalctl not available.\" >&2\n    exit 1\n  fi\nelse\n  if [[ ! -f \"$LOG_FILE\" ]]; then\n    echo \"Error: Log file '$LOG_FILE' does not exist.\" >&2\n    exit 1\n  fi\n  tail -n \"$LINE_COUNT\" \"$LOG_FILE\"\nfi\n"
        }
      ],
      "status": "success",
