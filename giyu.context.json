      "solution": {
        "approach": "Design a lightweight diagnostic procedure using the 'ping' command targeting Google's public DNS server (8.8.8.8). Execute a single ping request with a short timeout to avoid hanging. Use shell command execution for portability and minimal overhead.",
        "algorithm": "Execute: `ping -c 1 -W 3 8.8.8.8` and interpret exit code and output.",
        "complexity": "O(1)"
      },
      "dependencies": [],
      "status": "pending"
    },
